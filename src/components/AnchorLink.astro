---
/**
 * AnchorLink component
 * Creates a link to a section with an emoji prefix.
 * Replaces the Eleventy shortcode: {% anchorLink "emoji", "text" %}
 * 
 * @example
 * <AnchorLink emoji="🔗" text="Introduction" />
 * Renders: <a href="#introduction">🔗 Introduction</a>
 */

interface Props {
  emoji: string;
  text: string;
}

const { emoji, text } = Astro.props;

const href = `#${text.toLowerCase().replace(/\s+/g, '-')}`;
---

<a href={href} class="underline underline-offset-4">{emoji} {text}</a>
