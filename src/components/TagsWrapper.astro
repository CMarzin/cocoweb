---
interface Props {
  tags: string[];
  lang?: "fr" | "en";
}

const { tags, lang } = Astro.props;

const tagsBasePath = lang === "en" ? "/tags" : "/fr/tags";

function tagPath(tag: string) {
  return `${tagsBasePath}/${tag.toLowerCase().replace(/\s+/g, "-")}/`;
}
---

{
  tags.map((tag) => (
    <a
      href={tagPath(tag)}
      class="text-[10px] uppercase tracking-[0.15em] px-2 py-0.5 border border-border text-muted transition-colors duration-200 hover:border-primary/40 hover:text-primary cursor-pointer active:scale-[0.96] z-10"
    >
      #{tag}
    </a>
  ))
}
