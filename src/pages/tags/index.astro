---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

// Try English content first, fallback to French
let posts = await getCollection("blog", ({ id }) => id.startsWith("en/"));
if (posts.length === 0) {
  posts = await getCollection("blog", ({ id }) => id.startsWith("fr/"));
}

// Extract all unique tags and count occurrences
const tagCounts = new Map<string, number>();

posts.forEach((post) => {
  post.data.tags.forEach((tag) => {
    const normalizedTag = tag.toLowerCase();
    tagCounts.set(normalizedTag, (tagCounts.get(normalizedTag) || 0) + 1);
  });
});

// Sort tags by count (descending), then alphabetically
const sortedTags = Array.from(tagCounts.entries()).sort((a, b) => {
  if (b[1] !== a[1]) return b[1] - a[1];
  return a[0].localeCompare(b[0]);
});
---

<BaseLayout
  title="Tags - Cocoweb"
  description="All tags on the Cocoweb blog."
  lang="en"
>
  <div class="tags-page stagger-children">
    <h1
      class="font-display text-3xl sm:text-4xl text-foreground animate-fade-up mt-1"
    >
      Tags
    </h1>
    <p class="mt-5 animate-fade-up">
      Explore my tech watch and web discoveries by tags.
    </p>
    <p class="mt-2 animate-fade-up">
      <span class="tags-count text-primary text-glow tabular-nums"
        >{sortedTags.length}</span
      > tags available as of now.
    </p>

    <ul class="mt-5 flex gap-4 flex-wrap tablet:w-full stagger-children">
      {
        sortedTags.map(([tag, count]) => (
          <li class="animate-fade-up">
            <a
              href={`/tags/${tag.replace(/\s+/g, "-")}/`}
              class="text-xs uppercase tracking-[0.15em] px-4 py-1 border border-border text-muted-foreground transition-colors duration-200 hover:border-primary/40 hover:text-primary cursor-pointer active:scale-[0.96] z-10"
            >
              <span>{count}</span>
              <span>#{tag}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</BaseLayout>
