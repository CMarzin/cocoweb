---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';

export async function getStaticPaths() {
  let articles = await getCollection('articles', ({ id }) => id.startsWith('en/'));
  let isFallback = false;
  
  if (articles.length === 0) {
    articles = await getCollection('articles', ({ id }) => id.startsWith('fr/'));
    isFallback = true;
  }
  
  return articles.map((article) => ({
    params: { slug: article.id.replace(/^(en|fr)\//, '') },
    props: { article, isFallback },
  }));
}

const { article, isFallback } = Astro.props;
const { Content } = await render(article);
---

<ArticleLayout frontmatter={article.data} slug={article.id} lang="en" showTranslationNotice={isFallback}>
  <Content />
</ArticleLayout>
