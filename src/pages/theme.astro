                      <span class="inline-block w-6 h-6 rounded-sm border border-border/50 shrink-0" style={`background:hsl(${c.hsl})`} />
                      <span class="font-mono">{c.hsl}</span>
                    </div>
                  </td>
                  <td class="py-2 pr-3">
                    <div class="flex items-center gap-2">
                      <div class="inline-flex rounded-sm border border-border/50 overflow-hidden shrink-0" title={match ? "Identique" : `Hex: ${c.hex} vs HSL: ${c.hsl}`}>
                        <span class="block w-5 h-8" style={`background:${c.hex}`} />
                        <span class="block w-px h-8 bg-foreground/20" />
                        <span class="block w-5 h-8" style={`background:hsl(${c.hsl})`} />
                      </div>
                      {match
                        ? <span class="text-green-400">✓</span>
                        : <span class="text-yellow-400">≠</span>
                      }
                    </div>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Accent Colors 600 (Light mode) -->
    <section>
      <h2 class="font-display text-2xl font-light text-primary mb-2">Accent colors — 600 (light mode)</h2>
      <p class="text-muted-foreground text-xs mb-4">Utilisées en light mode pour la syntaxe et les accents.</p>
      <div class="overflow-x-auto">
        <table class="w-full text-xs border-collapse">
          <thead>
            <tr class="border-b text-left text-muted-foreground">
              <th class="py-2 pr-3">Nom</th>
              <th class="py-2 pr-3">Officiel (hex)</th>
              <th class="py-2 pr-3">HSL exact</th>
              <th class="py-2 pr-3">Swatch</th>
            </tr>
          </thead>
          <tbody>
            {accentColors600.map(c => {
              const exactHsl = hexToHsl(c.hex);
              return (
                <tr class="border-b border-border/50">
                  <td class="py-2 pr-3 font-mono">{c.name}</td>
                  <td class="py-2 pr-3">
                    <div class="flex items-center gap-2">
                      <span class="inline-block w-6 h-6 rounded-sm border border-border/50 shrink-0" style={`background:${c.hex}`} />
                      <span class="font-mono">{c.hex}</span>
                    </div>
                  </td>
                  <td class="py-2 pr-3 font-mono text-muted-foreground">{exactHsl}</td>
                  <td class="py-2 pr-3">
                    <span class="inline-block w-6 h-6 rounded-sm border border-border/50" style={`background:hsl(${exactHsl})`} />
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Extended Palette -->
    <section>
      <h2 class="font-display text-2xl font-light text-primary mb-2">Extended palette</h2>
      <p class="text-muted-foreground text-xs mb-6">La palette complète Flexoki 2.0 — valeurs 50 à 950 pour chaque couleur d'accent.</p>

      {Object.entries(extendedPalette).map(([colorName, steps]) => (
        <div class="mb-8">
          <h3 class="font-mono text-sm text-foreground mb-3 capitalize">{colorName}</h3>
          <div class="flex flex-wrap gap-1">
            {steps.map(s => (
              <div class="flex flex-col items-center gap-1">
                <span
                  class="block w-10 h-10 rounded-sm border border-border/50"
                  style={`background:${s.hex}`}
                  title={`${colorName}-${s.step}: ${s.hex}`}
                />
                <span class="text-[10px] text-muted-foreground font-mono">{s.step}</span>
              </div>
            ))}
          </div>
          <div class="flex flex-wrap gap-1 mt-1">
            {steps.map(s => (
              <div class="w-10 text-center">
                <span class="text-[9px] text-muted-foreground/60 font-mono break-all leading-tight">{s.hex}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </section>

    <!-- Base ramp visual -->
    <section>
      <h2 class="font-display text-2xl font-light text-primary mb-4">Base ramp</h2>
      <div class="flex gap-1 mb-2">
        {baseColors.map(c => (
          <div class="flex flex-col items-center gap-1 flex-1 min-w-0">
            <span
              class="block w-full h-16 rounded-sm border border-border/50"
              style={`background:${c.hex}`}
              title={`${c.name}: ${c.hex}`}
            />
            <span class="text-[9px] text-muted-foreground font-mono truncate w-full text-center">{c.name}</span>
          </div>
        ))}
      </div>
      <p class="text-[10px] text-muted-foreground/60">Hex officiel ↑ / HSL du site ↓</p>
      <div class="flex gap-1 mt-1">
        {baseColors.map(c => (
          <div class="flex flex-col items-center gap-1 flex-1 min-w-0">
            <span
              class="block w-full h-16 rounded-sm border border-border/50"
              style={`background:hsl(${c.hsl})`}
              title={`${c.name}: hsl(${c.hsl})`}
            />
          </div>
        ))}
