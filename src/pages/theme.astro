    </section>

    <!-- Reference link -->
    <section class="border-t pt-6 text-xs text-muted-foreground">
      <p>
        Référence : <a href="https://stephango.com/flexoki" class="text-accent hover:underline" target="_blank" rel="noopener">stephango.com/flexoki</a>
