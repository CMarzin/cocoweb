function hexToHsl(hex: string): string {
  const r = parseInt(hex.slice(1, 3), 16) / 255;
  const g = parseInt(hex.slice(3, 5), 16) / 255;
  const b = parseInt(hex.slice(5, 7), 16) / 255;
  const max = Math.max(r, g, b);
  const min = Math.min(r, g, b);
  const l = (max + min) / 2;
  if (max === min) return `0 0% ${Math.round(l * 100)}%`;
  const d = max - min;
  const s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
  let h = 0;
  if (max === r) h = ((g - b) / d + (g < b ? 6 : 0)) / 6;
  else if (max === g) h = ((b - r) / d + 2) / 6;
  else h = ((r - g) / d + 4) / 6;
  return `${Math.round(h * 360)} ${Math.round(s * 100)}% ${Math.round(l * 100)}%`;
}

const semanticMappings = [
  { role: "background",      darkVar: "--background",      lightVar: "--background",      darkDesc: "bg", lightDesc: "bg" },
  { role: "foreground",       darkVar: "--foreground",       lightVar: "--foreground",       darkDesc: "tx", lightDesc: "tx" },
  { role: "card",             darkVar: "--card",             lightVar: "--card",             darkDesc: "bg-2", lightDesc: "bg-2" },
  { role: "primary",          darkVar: "--primary",          lightVar: "--primary",          darkDesc: "yellow-400", lightDesc: "magenta" },
  { role: "secondary",        darkVar: "--secondary",        lightVar: "--secondary",        darkDesc: "base-900", lightDesc: "base-100" },
  { role: "muted",            darkVar: "--muted",            lightVar: "--muted",            darkDesc: "base-850", lightDesc: "base-150" },
  { role: "muted-foreground", darkVar: "--muted-foreground", lightVar: "--muted-foreground", darkDesc: "base-600", lightDesc: "base-600" },
  { role: "accent",           darkVar: "--accent",           lightVar: "--accent",           darkDesc: "cyan-400", lightDesc: "cyan-400" },
  { role: "destructive",      darkVar: "--destructive",      lightVar: "--destructive",      darkDesc: "red-600", lightDesc: "red-600" },
  { role: "border",           darkVar: "--border",           lightVar: "--border",           darkDesc: "base-800", lightDesc: "base-200" },
];
---

<BaseLayout title="Theme — Flexoki Color Reference" description="Comparison of Flexoki official hex colors and the HSL values used on this site.">
  <div class="space-y-12 animate-fade-up">

    <section>
      <h1 class="font-display text-4xl font-light tracking-tight text-primary text-glow mb-2">
        Flexoki Theme
      </h1>
      <p class="text-muted-foreground text-sm mb-8">
        Comparaison des couleurs hex officielles <a href="https://stephango.com/flexoki" class="text-accent hover:underline" target="_blank" rel="noopener">Flexoki</a> avec les valeurs HSL utilisées sur ce site.
      </p>
    </section>

    <!-- Semantic Mappings -->
    <section>
      <h2 class="font-display text-2xl font-light text-primary mb-4">Semantic tokens</h2>
      <p class="text-muted-foreground text-xs mb-4">Correspondances des variables CSS du design system — valeurs dark / light.</p>
      <div class="overflow-x-auto">
        <table class="w-full text-xs border-collapse">
          <thead>
            <tr class="border-b text-left text-muted-foreground">
              <th class="py-2 pr-3">Rôle</th>
              <th class="py-2 pr-3">Dark (source)</th>
              <th class="py-2 pr-3">Light (source)</th>
            </tr>
          </thead>
          <tbody>
            {semanticMappings.map(m => (
              <tr class="border-b border-border/50">
                <td class="py-2 pr-3 font-mono">{m.role}</td>
                <td class="py-2 pr-3">
                  <div class="flex items-center gap-2">
                    <span class="text-muted-foreground">{m.darkDesc}</span>
                  </div>
                </td>
                <td class="py-2 pr-3">
                  <div class="flex items-center gap-2">
                    <span class="text-muted-foreground">{m.lightDesc}</span>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Base Colors -->
    <section>
      <h2 class="font-display text-2xl font-light text-primary mb-4">Base colors</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-xs border-collapse">
          <thead>
            <tr class="border-b text-left text-muted-foreground">
              <th class="py-2 pr-3">Nom</th>
              <th class="py-2 pr-3">Officiel (hex)</th>
              <th class="py-2 pr-3">HSL exact</th>
              <th class="py-2 pr-3">Mon HSL</th>
              <th class="py-2 pr-3">Diff visuelle</th>
            </tr>
          </thead>
          <tbody>
            {baseColors.map(c => {
              const exactHsl = hexToHsl(c.hex);
              const match = exactHsl === c.hsl;
              return (
                <tr class="border-b border-border/50">
                  <td class="py-2 pr-3 font-mono">{c.name}</td>
                  <td class="py-2 pr-3">
                    <div class="flex items-center gap-2">
                      <span class="inline-block w-6 h-6 rounded-sm border border-border/50 shrink-0" style={`background:${c.hex}`} />
                      <span class="font-mono">{c.hex}</span>
                    </div>
                  </td>
                  <td class="py-2 pr-3">
                    <div class="flex items-center gap-2">
                      <span class="inline-block w-6 h-6 rounded-sm border border-border/50 shrink-0" style={`background:hsl(${exactHsl})`} />
                      <span class="font-mono text-muted-foreground">{exactHsl}</span>
                    </div>
                  </td>
                  <td class="py-2 pr-3">
                    <div class="flex items-center gap-2">
                      <span class="inline-block w-6 h-6 rounded-sm border border-border/50 shrink-0" style={`background:hsl(${c.hsl})`} />
                      <span class="font-mono">{c.hsl}</span>
                    </div>
                  </td>
                  <td class="py-2 pr-3">
                    <div class="flex items-center gap-2">
                      <div class="inline-flex rounded-sm border border-border/50 overflow-hidden shrink-0" title={match ? "Identique" : `Hex: ${c.hex} vs HSL: ${c.hsl}`}>
                        <span class="block w-5 h-8" style={`background:${c.hex}`} />
                        <span class="block w-px h-8 bg-foreground/20" />
                        <span class="block w-5 h-8" style={`background:hsl(${c.hsl})`} />
                      </div>
                      {match
                        ? <span class="text-green-400">✓</span>
                        : <span class="text-yellow-400">≠</span>
                      }
                    </div>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Accent Colors 400 (Dark mode) -->
    <section>
      <h2 class="font-display text-2xl font-light text-primary mb-2">Accent colors — 400 (dark mode)</h2>
