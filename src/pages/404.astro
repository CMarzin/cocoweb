---
import BaseLayout from "../layouts/BaseLayout.astro";
import { useTranslations } from "../i18n/utils";

const t = useTranslations("en");
---

<BaseLayout
  title="Page not found - Cocoweb"
  description="The page you are looking for does not exist."
  lang="en"
>
  <div class="flex flex-col justify-center items-center">
    <h1
      class="font-display text-3xl sm:text-4xl font-light text-foreground animate-fade-up mt-1"
    >
      404
    </h1>
    <p class="mt-8">{t("404.description")}</p>
    <a
      class="mt-5 text-accent underline underline-offset-4 decoration-accent/30 hover:decoration-accent transition-colors duration-200 active:scale-[0.97]"
      href="/">{t("404.back")}</a
    >
  </div>
</BaseLayout>
