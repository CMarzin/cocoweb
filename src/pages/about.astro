---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="About - Cocoweb"
  description="About Corentin Marzin and the Cocoweb blog."
  ogImage="/img/og-cocoweb.webp"
  lang="en"
>
  <article class="about">
    <h1
      class="font-display text-4xl  tracking-tight text-foreground animate-fade-up"
    >
      About
    </h1>

    <p class="mt-5">Welcome to my corner of the web.</p>

    <p>I am Corentin, I make digital interfaces for people.</p>

    <p>
      In this blog, I share my tech watch mainly and sometimes I write articles
      about things I do at work.
    </p>

    <h2 class="mt-5 font-display text-2xl text-foreground">
      My projects and links
    </h2>

    <ul class="mt-5 flex flex-col gap-2 list-disc">
      <li>
        <a
          href="https://github.com/CMarzin/cli-mr-creator"
          target="_blank"
          rel="noopener"
          class="text-accent underline underline-offset-4 decoration-accent/30 hover:decoration-accent transition-colors duration-200 active:scale-[0.97]"
        >
          An npm package for creating merge request from your cli
        </a>
      </li>
      <li>
        <a
          href="https://corentinmarzin.fr"
          target="_blank"
          rel="noopener"
          class="text-accent underline underline-offset-4 decoration-accent/30 hover:decoration-accent transition-colors duration-200 active:scale-[0.97]"
        >
          My personal and latest folio
        </a>
      </li>
      <li>
        <a
          href="https://unsplash.com/@marzin_corentin"
          target="_blank"
          rel="noopener"
          class="text-accent underline underline-offset-4 decoration-accent/30 hover:decoration-accent transition-colors duration-200 active:scale-[0.97]"
        >
          My photography portfolio on Unsplash
        </a>
      </li>
      <li>
        <a href="https://github.com/CMarzin" target="_blank" rel="noopener" class="text-accent underline underline-offset-4 decoration-accent/30 hover:decoration-accent transition-colors duration-200 active:scale-[0.97]">
          My Github account
        </a>
      </li>
      <li>
        <a href="https://ysf.cocommit.fr/" target="_blank" rel="noopener" class="text-accent underline underline-offset-4 decoration-accent/30 hover:decoration-accent transition-colors duration-200 active:scale-[0.97]">
          A never published project, but I am still proud of the animations
        </a>
      </li>
      <li>
        <a href="https://x.com/marz_coco" target="_blank" rel="noopener" class="text-accent underline underline-offset-4 decoration-accent/30 hover:decoration-accent transition-colors duration-200 active:scale-[0.97]">
          My twitter account
        </a>
      </li>
      <li>
        <a
          href="https://haddock-fury.cocommit.fr/"
          target="_blank"
          rel="noopener"
          class="text-accent underline underline-offset-4 decoration-accent/30 hover:decoration-accent transition-colors duration-200 active:scale-[0.97]"
        >
          A vibe coded yolo insult generator
        </a>
      </li>
    </ul>
  </article>
</BaseLayout>
